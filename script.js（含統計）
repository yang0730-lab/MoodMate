let mood = "neutral";

let data = {
happy: 0,
neutral: 0,
sad: 0,
angry: 0,
tired: 0
};

function selectMood(m){
mood = m;
data[m]++;
drawChart();
}

function submitEntry(){

let text = document.getElementById("input").value.toLowerCase();
let reply = "";

if(text.includes("tired") || mood==="tired"){
reply = "You seem exhausted. Rest is important.";
}
else if(text.includes("stress")){
reply = "Take it step by step. You are doing fine.";
}
else if(mood==="sad"){
reply = "I'm here for you. It will get better.";
}
else if(mood==="happy"){
reply = "Great! Keep this positive energy 🌿";
}
else{
reply = "Thank you for sharing.";
}

document.getElementById("response").innerText = reply;
}

function drawChart(){

let canvas = document.getElementById("chart");
let ctx = canvas.getContext("2d");

let total = Object.values(data).reduce((a,b)=>a+b,0);
if(total === 0) return;

let colors = {
happy:"#4ecdc4",
neutral:"#c0c0c0",
sad:"#74b9ff",
angry:"#ff7675",
tired:"#ffeaa7"
};

let start = 0;
ctx.clearRect(0,0,300,300);

for(let key in data){
let slice = (data[key]/total) * 2 * Math.PI;

ctx.beginPath();
ctx.moveTo(150,150);
ctx.arc(150,150,100,start,start+slice);
ctx.fillStyle = colors[key];
ctx.fill();

start += slice;
}
}
